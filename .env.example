# WebSocket URL of the zwave-js-server exposed by Z-Wave JS UI.
# This is the "Z-Wave JS Server" port (default 3000), NOT the 8091 web UI.
ZWAVE_JS_URL=ws://localhost:3000

# Set to 1/true/yes/on to lock the server to read-only tools (all write and
# admin/lifecycle tools then refuse before touching the network). Unset = writes allowed.
# ZWAVE_JS_READ_ONLY=1
